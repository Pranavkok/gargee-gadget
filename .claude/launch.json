{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "website",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const mime={'html':'text/html','css':'text/css','js':'application/javascript','svg':'image/svg+xml'};const base=process.cwd();http.createServer((req,res)=>{let url=req.url.split('?')[0];if(url==='/') url='/index.html';const fp=path.join(base,url);fs.readFile(fp,(err,data)=>{if(err){res.writeHead(404);res.end('Not found');return;}const ext=path.extname(fp).slice(1);res.writeHead(200,{'Content-Type':mime[ext]||'text/plain'});res.end(data);});}).listen(3000,()=>console.log('ok'));"],
      "port": 3000
    }
  ]
}
